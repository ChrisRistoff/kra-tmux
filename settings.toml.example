[autosave]
active = true
currentSession = "this will update automatically on load/save session"
timeoutMs = 20000

# ─── Persistent project memory (kra-memory MCP) ───────────────────────────────
# The kra-memory layer gives the agent persistent notes (`remember` / `recall`
# / `update_memory`) and conceptual codebase search (`semantic_search`) backed
# by a local LanceDB + bundled BGE-small embedder. Storage lives in
# <repo>/.kra-memory/ and is gitignored by default.
#
# Run `kra ai index` once per repo to build the initial code index, then
# enable `indexCodeOnSave` to keep it fresh in the background.
[ai.agent.memory]
enabled = true              # master switch for the whole memory layer
indexCodeOnStart = false    # full reindex when an agent session starts
indexCodeOnSave = false     # background watcher that reindexes files on save
autoSurfaceOnStart = false  # auto-recall relevant notes / open revisits at session preamble
gitignoreMemory = true      # documentation-only: whether you keep .kra-memory/ in .gitignore
# Tune the chunker (defaults are good for most repos):
# chunkLines = 80
# chunkOverlap = 5
# includeExtensions = [".ts", ".js", ".py", ".go", ".rs", ".md"]
# excludeGlobs = ["node_modules/**", "dest/**", "coverage/**", ".kra-memory/**"]

# ─── Optional sub-agents (executor + investigator) ────────────────────────────
# Two opt-in helpers that let a smaller, cheaper model do bulk work while your
# main orchestrator model focuses on reasoning. Enable either independently.
#
# When `enabled = true`, the BYOK start flow asks you to pick a provider +
# model for that sub-agent (right after the orchestrator picker). Pricing for
# both shows up alongside the orchestrator in the in-session cost counter.
#
# Executor   – consumes a plan from the orchestrator, runs it (reads/edits/runs
#              tests), returns a structured event log. You can interrupt at any
#              point with Ctrl-C, or hand off manually with `/exec`.
# Investigator – exposed to the orchestrator as a single `investigate` tool.
#              Goes off, gathers relevant evidence from the codebase, returns
#              a curated synthesis instead of dumping raw file contents.
[ai.agent.executor]
enabled = false               # master switch; off by default
useInvestigatorRuntime = true # if true (and investigator enabled) reuse its provider+model;
                              # if false you'll be prompted to pick a separate one on startup
allowInterrupt = true         # Ctrl-C returns control to orchestrator with partial log
allowReplanEscape = true      # executor may emit needs_replan; orchestrator replans
includeDiffsInLog = true      # event log carries inline diffs for edits
maxToolCalls = 60             # hard cap on tool calls before the executor is forced to submit
# Restrict the toolset the executor is allowed to call (defaults shown):
# toolWhitelist = ["read_lines", "get_outline", "edit", "create_file",
#                  "search", "lsp_query", "bash"]

[ai.agent.investigator]
enabled = false               # master switch; off by default
maxEvidenceItems = 8          # cap on evidence array returned to orchestrator
maxExcerptLines = 20          # cap on lines per excerpt
validateExcerpts = true       # reject hallucinated snippets at the tool layer
# Restrict the toolset the investigator is allowed to call (defaults shown):
# toolWhitelist = ["semantic_search", "search", "get_outline", "read_lines",
#                  "lsp_query", "docs_search", "recall"]

# ─── Quota dashboard (`kra ai quota-agent`) ──────────────────────────────────
# Per-provider toggles for which sections the quota dashboard renders, and
# whether the in-session quota tracker emits warnings when thresholds are
# crossed (50% / 25% / 10% remaining). Both default to true.
#
# Copilot pulls monthly + session limits from the GitHub API + cached
# `assistant.usage` snapshots. Claude pulls subscription rate-limit info
# (5-hour, 7-day, Opus/Sonnet weekly, overage) from `SDKRateLimitEvent`
# messages emitted during Pro/Max OAuth sessions. API-key users won't see
# Claude data because Anthropic's API doesn't surface rate-limit events.
[ai.agent.quota]
copilot = true
claude = true

# ─── Documentation indexing (kra memory) ───────────────────────────────────────────
# Crawls the documentation sites listed below with Crawl4AI, embeds each page,
# and stores chunks in a `doc_chunks` LanceDB table next to `code_chunks`.
# The agent retrieves docs via the same kra-memory `semantic_search` MCP tool.
#
# Run `kra memory` to open the interactive dashboard. From there you can:
#   - install/re-install the isolated Crawl4AI venv (~507 MB at ~/.kra/crawl4ai-venv/)
#   - list configured sources (with chunk counts) and crawl/drop them per-source
#   - crawl all sources (with optional --full bypass of the incremental cache)
#   - watch live progress (auto-refreshing) and stop the coordinator cleanly
# ─── Live web fetch (web_fetch tool) ──────────────────────────────────────────
# Backs the agent's `web_fetch` tool with a long-lived Crawl4AI worker that
# keeps a Chromium context warm across requests, so JS-rendered/SPA pages
# resolve in ~1s after the first cold start (~3-5s). Falls back to Jina Reader
# and then a direct fetch if Crawl4AI is unavailable or fails.
#
# The worker is lazy-spawned on first call, recycled after `fetchMaxPagesPerWorker`
# pages, and shut down after `fetchIdleTimeoutMs` of inactivity. `fetchMode`
# picks the default rendering strategy when the tool is called without an
# explicit `mode` arg: 'http' is fast/static, 'browser' executes JS, 'auto'
# tries http first and escalates to browser on heuristic failure.
[ai.web]
fetchEnabled = true
fetchIdleTimeoutMs = 120000      # shut the worker down after 2 min idle
fetchMaxPagesPerWorker = 50      # recycle Chromium after this many pages
fetchPageTimeoutMs = 30000       # per-page navigation/render budget
fetchMode = "auto"               # "auto" | "http" | "browser"
fetchMaxConcurrent = 3           # in-flight requests against the single worker


[ai.docs]
enabled = true                  # opt-in; flip to true once Crawl4AI is installed
maxConcurrentSources = 2        # how many Crawl4AI subprocesses run in parallel
idleTimeoutMs = 30000           # coordinator self-exits after this idle period
cacheRawMarkdown = true         # keep raw .md per page so re-chunking skips re-crawl

[[ai.docs.sources]]

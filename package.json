{
    "name": "kra-workflow",
    "_moduleAliases": {
        "@": "dest/src"
    },
    "version": "2.0.0",
    "description": "CLI for tmux session management, git workflow helpers, and an AI agent layer.",
    "keywords": [
        "tmux",
        "cli",
        "workflow",
        "git",
        "ai",
        "agent",
        "productivity"
    ],
    "engines": {
        "node": ">=18"
    },
    "bin": {
        "kra": "bin/kra.js"
    },
    "preferGlobal": true,
    "files": [
        "bin",
        "dest",
        "automationScripts",
        "settings.toml.example",
        "start.js",
        "README.md",
        "LICENSE.md",
        "AGENT.md"
    ],
    "scripts": {
        "build": "tsc",
        "prepublishOnly": "rm -rf dest && tsc",
        "postinstall": "node bin/postinstall.js",
        "lint": "eslint --fix",
        "test": "jest",
        "test:coverage": "jest --coverage"
    },
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@anthropic-ai/claude-agent-sdk": "^0.2.132",
        "@github/copilot-sdk": "^0.2.2",
        "@lancedb/lancedb": "^0.27.2",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "apache-arrow": "^18.1.0",
        "blessed": "^0.1.81",
        "chalk": "^5.6.0",
        "chalk-animation": "^2.0.3",
        "cheerio": "^1.2.0",
        "chokidar": "^5.0.0",
        "cli-highlight": "^2.1.11",
        "dotenv": "^16.4.7",
        "events": "^3.3.0",
        "fastembed": "^2.1.0",
        "figlet": "^1.8.2",
        "html-to-text": "^9.0.5",
        "marked": "^15.0.12",
        "marked-terminal": "^7.3.0",
        "module-alias": "^2.2.3",
        "neovim": "^4.0.0",
        "openai": "^6.0.0",
        "smol-toml": "^1.4.2",
        "tsconfig-paths": "^4.2.0",
        "vscode-languageserver-protocol": "^3.17.5",
        "zod": "^4.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.19.0",
        "@types/blessed": "^0.1.25",
        "@types/events": "^3.0.3",
        "@types/figlet": "^1.7.0",
        "@types/html-to-text": "^9.0.4",
        "@types/jest": "^29.5.14",
        "@types/node": "^22.7.4",
        "@typescript-eslint/eslint-plugin": "^8.24.0",
        "@typescript-eslint/parser": "^8.24.0",
        "eslint": "^9.20.1",
        "globals": "^15.14.0",
        "jest": "^29.7.0",
        "jest-mock": "^29.7.0",
        "ts-jest": "^29.2.5",
        "typescript": "^5.6.2",
        "typescript-eslint": "^8.22.0"
    }
}
